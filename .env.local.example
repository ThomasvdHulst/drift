# Copy this file to `.env.local` (git-ignored) and adjust as needed.

# Sent as the Api-User-Agent header on every Wikimedia request, per their etiquette.
# Please put a real contact URL/email if you fork this.
WIKI_USER_AGENT="Drift/0.1 (local hobby project; https://example.com)"

# ---------------------------------------------------------------------------
# Papers realm (Phase 17 — arXiv). Experimental / off by default. Set to "1" to
# show the "Papers" tab (arXiv preprints, CC0 metadata only, text-forward cards).
# Unset/absent ⇒ no Papers tab, nothing else changes. Drop the realm entirely by
# leaving this off. arXiv etiquette: an Api-User-Agent (put a real contact if you fork).
# ---------------------------------------------------------------------------
# NEXT_PUBLIC_REALM_PAPERS=1
# ARXIV_USER_AGENT="Drift/0.1 (local hobby project; https://example.com)"

# ---------------------------------------------------------------------------
# Supabase — accounts & cloud sync (Phase 9). Optional for LOCAL dev: with these
# unset the app runs exactly as before, fully local (IndexedDB only), no sign-in.
# REQUIRED for the HOSTED app (Phase 13): when these are set the app requires an
# account (a sign-in gate) and each account's data is private to it. Create a free
# project at https://supabase.com, copy its URL + keys here. Deploy: see docs/deploy.md.
# ---------------------------------------------------------------------------
# Browser-exposed (safe: per-user access is enforced by Row-Level Security).
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
#
# Social sign-in buttons to SHOW — a comma list of providers you've enabled in
# Supabase (Auth → Providers). Only listed providers get a button, so you never
# show one that isn't wired up. Empty/unset ⇒ email + password only.
# NEXT_PUBLIC_OAUTH_PROVIDERS=google        # or: google,apple
#
# Server-only — used ONLY by scripts/verify-supabase.mjs. NEVER expose to the
# browser (never give it a NEXT_PUBLIC_ prefix): it bypasses Row-Level Security.
# SUPABASE_SECRET_KEY=sb_secret_xxx
# SUPABASE_EMAIL=you@example.com      # a test account, for the verify script
# SUPABASE_PASSWORD=your-test-password

# ---------------------------------------------------------------------------
# AI layer (Phase 3 — not used yet). Left here so the shape is documented.
# The app works fully with these unset/false; Ollama is always optional.
# ---------------------------------------------------------------------------
# AI_THREADS=false
# AI_REWRITE=false
# OLLAMA_MODEL=qwen2.5:14b
