# Copy this file to `.env.local` (git-ignored) and adjust as needed.

# Sent as the Api-User-Agent header on every Wikimedia request. This is REQUIRED in
# production, not just polite: Wikimedia's 2025 global limits give a COMPLIANT
# User-Agent (a resolvable URL + a contact email) ~200 requests/min per IP, but an
# "unidentified" one only ~10/min. Since the hosted app egresses through one shared
# IP, every user draws on that one budget, so keep this real. Put your own site URL
# + contact email. See docs/beta-readiness.md (Q3).
WIKI_USER_AGENT="Drift/1.0 (https://www.usedrift.org; you@your-domain)"
# Same etiquette for the other realms' upstreams (optional; sensible defaults exist):
# ARTIC_USER_AGENT="Drift/1.0 (https://www.usedrift.org; you@your-domain)"

# ---------------------------------------------------------------------------
# Papers realm (Phase 17 — arXiv). Experimental / off by default. Set to "1" to
# show the "Papers" tab (arXiv preprints, CC0 metadata only, text-forward cards).
# Unset/absent ⇒ no Papers tab, nothing else changes. Drop the realm entirely by
# leaving this off. arXiv etiquette: an Api-User-Agent (put a real contact if you fork).
# ---------------------------------------------------------------------------
# NEXT_PUBLIC_REALM_PAPERS=1
# ARXIV_USER_AGENT="Drift/1.0 (https://www.usedrift.org; you@your-domain)"

# ---------------------------------------------------------------------------
# Supabase — accounts & cloud sync (Phase 9). Optional for LOCAL dev: with these
# unset the app runs exactly as before, fully local (IndexedDB only), no sign-in.
# REQUIRED for the HOSTED app (Phase 13): when these are set the app requires an
# account (a sign-in gate) and each account's data is private to it. Create a free
# project at https://supabase.com, copy its URL + keys here. Deploy: see docs/deploy.md.
# ---------------------------------------------------------------------------
# Browser-exposed (safe: per-user access is enforced by Row-Level Security).
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
#
# Social sign-in buttons to SHOW — a comma list of providers you've enabled in
# Supabase (Auth → Providers). Only listed providers get a button, so you never
# show one that isn't wired up. Empty/unset ⇒ email + password only.
# NEXT_PUBLIC_OAUTH_PROVIDERS=google        # or: google,apple
#
# Server-only — used by scripts/verify-supabase.mjs AND the server routes
# /api/account/delete + /api/email/welcome (they need it to remove the auth user /
# stamp welcomed). NEVER expose to the browser (never give it a NEXT_PUBLIC_
# prefix): it bypasses Row-Level Security. Also set it in Vercel (server-only).
# SUPABASE_SECRET_KEY=sb_secret_xxx
# SUPABASE_EMAIL=you@example.com      # a test account, for the verify script
# SUPABASE_PASSWORD=your-test-password

# ---------------------------------------------------------------------------
# Email — transactional email (Phase 19). Confirm + reset are sent by Supabase via
# your Resend SMTP; the welcome (after verifying) + goodbye (after deleting) emails
# are sent by the app directly through the Resend HTTP API, so it needs a key.
# All graceful: unset ⇒ those two custom emails are skipped, nothing else breaks.
# Set RESEND_API_KEY (server-only) in Vercel too.
# ---------------------------------------------------------------------------
# RESEND_API_KEY=re_xxx
# EMAIL_FROM="Drift <noreply@usedrift.org>"
# NEXT_PUBLIC_SITE_URL=https://www.usedrift.org   # for links + the logo in emails

# ---------------------------------------------------------------------------
# Ads (Phase 21 — experimental, OFF by default). A single calm "Sponsored" card
# every N drifts, never saved to a trail. UNSET ⇒ no ads, no script, no cookies:
# byte-for-byte the ad-free app. This is the kill switch (toggling = a redeploy).
#   NEXT_PUBLIC_ADS_ENABLED=1                # "1" turns ads on; anything else = off
#   NEXT_PUBLIC_ADS_MODE=placeholder         # "placeholder" (house card, local test) | "adsense"
#   NEXT_PUBLIC_ADS_EVERY=5                  # show an ad after this many drift-scrolls (default 5)
# Real AdSense. Set the CLIENT id alone to load the AdSense loader script so Google
# can REVIEW the live site (no visible ads yet — this is the "under review" state):
#   NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX
# Then, once approved AND you've created an in-feed ad unit, add the slot and flip
# the switches to actually SHOW the in-feed ad:
#   NEXT_PUBLIC_ADS_ENABLED=1
#   NEXT_PUBLIC_ADS_MODE=adsense
#   NEXT_PUBLIC_ADSENSE_SLOT=XXXXXXXXXX
# (public/ads.txt already carries the publisher line; enable the consent message in AdSense.)
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# AI layer (Phase 3 — not used yet). Left here so the shape is documented.
# The app works fully with these unset/false; Ollama is always optional.
# ---------------------------------------------------------------------------
# AI_THREADS=false
# AI_REWRITE=false
# OLLAMA_MODEL=qwen2.5:14b
